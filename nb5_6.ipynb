   "source": [
    "# 딕셔너리(dictionary)\n",
    "- key : value 구조\n",
    "\n",
    "- 순서 O (Python 3.7 이상)\n",
    "\n",
    "- key는 중복 불가, value는 중복 가능"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "f3692e5d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "{'a': 1, 'b': 2}\n",
      "{'a': 1, 'b': 2}\n",
      "{'a': 1, 'b': 2}\n"
     ]
    }
   ],
   "source": [
    "# dict 자료형 생성, 다루기\n",
    "# 방법 1\n",
    "d1 = {\"a\" : 1, \"b\" : 2}\n",
    "\n",
    "# 방법 2\n",
    "d2 = dict(a = 1, b = 2)\n",
    "\n",
    "# 방법 3\n",
    "d3 = dict([(\"a\", 1), (\"b\", 2)])\n",
    "\n",
    "print(d1)\n",
    "print(d2)\n",
    "print(d3)"
   ]
  },
